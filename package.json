{
  "name": "factory-ops-intelligence-platform",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "install:web": "npm --prefix apps/web-dashboard install",
    "dev:web": "npm --prefix apps/web-dashboard run dev",
    "build:web": "npm --prefix apps/web-dashboard run build",
    "seed": "python scripts/seed_demo_data.py",
    "test": "python -m pytest tests",
    "smoke": "python scripts/smoke_demo.py",
    "check:tone": "python scripts/check_ai_tone.py",
    "self-check": "python scripts/self_check.py",
    "test:all": "python scripts/self_check.py && python -m pytest tests && python scripts/smoke_demo.py && python scripts/check_ai_tone.py && npm --prefix apps/web-dashboard run build"
  }
}

